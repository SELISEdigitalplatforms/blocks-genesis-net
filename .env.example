# Core secrets/configuration
BlocksSecret__CacheConnectionString=redis:6379,password=change_me,abortConnect=false
BlocksSecret__MessageConnectionString=amqp://guest:guest@rabbitmq:5672/
BlocksSecret__LogConnectionString=mongodb://mongo:27017/
BlocksSecret__MetricConnectionString=mongodb://mongo:27017/
BlocksSecret__TraceConnectionString=mongodb://mongo:27017/
BlocksSecret__LogDatabaseName=Logs
BlocksSecret__MetricDatabaseName=Metrics
BlocksSecret__TraceDatabaseName=Traces
BlocksSecret__DatabaseConnectionString=mongodb://mongo:27017/
BlocksSecret__RootDatabaseName=ROOT_DB
BlocksSecret__EnableHsts=true
BlocksSecret__AllowedCorsOrigins=https://app.example.com,https://admin.example.com

# Service identity
ASPNETCORE_ENVIRONMENT=Development
HTTP1_PORT=5000
HTTP2_PORT=5001

# Security hardening
# Max requests per minute per tenant (or per client IP when tenant header is absent)
BLOCKS_RATE_LIMIT_PER_MINUTE=120
